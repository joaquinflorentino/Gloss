{
  "manifest_version": 3,
  "name": "Gloss",
  "version": "1.0",
  "description": "Vocabulary learning through context",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {},
  "background": {
    "service_worker": "background.js"
  }
}